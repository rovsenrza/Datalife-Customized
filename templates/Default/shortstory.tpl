<article class="bg-white border border-atelier_outline/70 mb-5 overflow-hidden noise-bg">
	<div class="grid md:grid-cols-[280px_1fr] gap-0">
		<a class="block bg-atelier_low min-h-[220px]" href="{full-link}">
			<img class="w-full h-full object-cover" src="{image-1}" alt="{title}" onerror="this.onerror=null;this.src='https://placehold.co/900x700/f6f3ef/6b5e4b?text=STITCHES';">
		</a>
		<div class="p-5 md:p-6 stitch-line">
			<p class="font-label text-[11px] uppercase tracking-[0.14em] text-atelier_secondary mb-2">{date=d.m.Y}</p>
			<h2 class="font-headline text-3xl leading-tight mb-3"><a class="hover:text-atelier_primary transition-colors" href="{full-link}">{title}</a></h2>
			<p class="text-atelier_secondary leading-relaxed mb-4">{short-story limit="230"}</p>
			<a class="inline-flex items-center text-xs font-label uppercase tracking-wider text-atelier_primary" href="{full-link}">{lang_read_more}</a>
		</div>
	</div>
</article>
