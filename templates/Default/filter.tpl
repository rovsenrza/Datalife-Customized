<form class="dle-filters" data-dle-filter-form="1" action="{form_action}" method="get">
	{hidden_fields}
	<div class="dle-filters-items grid md:grid-cols-2 gap-4">
		{items}
	</div>
	<div class="dle-filters-actions mt-4 flex justify-end">
		<button class="inline-flex items-center justify-center h-10 px-4 border border-atelier_outline text-xs font-label uppercase tracking-wider" type="button" data-dle-filter-reset="1">{lang_filter_reset}</button>
	</div>
</form>
