<div class="swiper-slide">
	<article class="group bg-white border border-atelier_outline/70 overflow-hidden noise-bg">
		<a class="block aspect-[4/5] bg-atelier_low overflow-hidden" href="{full-link}">
			<img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" src="{image-1}" alt="{title}" onerror="this.onerror=null;this.src='https://placehold.co/720x900/f6f3ef/6b5e4b?text=STITCHES';">
		</a>
		<div class="p-4 stitch-line">
			<div class="flex items-center justify-between gap-3 mb-2">
				<p class="font-label text-[11px] uppercase tracking-[0.14em] text-atelier_secondary">[xfgiven_price][xfvalue_price][/xfgiven_price][xfnotgiven_price]{date=d.m.Y}[/xfnotgiven_price]</p>
			</div>
			<h3 class="font-headline text-2xl leading-tight mb-2"><a class="hover:text-atelier_primary transition-colors" href="{full-link}">{title}</a></h3>
			<p class="text-sm text-atelier_secondary leading-relaxed mb-4">{short-story limit="120"}</p>
			<a class="inline-flex items-center text-xs font-label uppercase tracking-wider text-atelier_primary" href="{full-link}">{lang_read_more}</a>
		</div>
	</article>
</div>
