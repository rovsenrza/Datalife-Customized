DirectoryIndex index.php

<IfModule mod_headers.c>
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<IfModule mod_rewrite.c>
	RewriteEngine On

	RewriteRule ^(az|en|ru)/?$ index.php?site_lang=$1 [QSA,L]
	RewriteRule ^(az|en|ru)/(.*)$ $2?site_lang=$1 [QSA,L]

	RewriteRule ^engine/data/.*\.(php|txt|db)$ - [F,L,NC]
	RewriteRule ^engine/cache/.*\.php$ - [F,L,NC]
	RewriteRule ^backup/.*$ - [F,L,NC]

	RewriteRule ^page/([0-9]+)(/?)$ index.php?cstart=$1 [QSA,L]

	RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})/page,([0-9]+),([0-9]+),(.*).html$ index.php?subaction=showfull&year=$1&month=$2&day=$3&news_page=$4&cstart=$5&news_name=$6&seourl=$6 [QSA,L]
	RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})/page,([0-9]+),(.*).html$ index.php?subaction=showfull&year=$1&month=$2&day=$3&news_page=$4&news_name=$5&seourl=$5 [QSA,L]
	RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})/print:page,([0-9]+),(.*).html$ index.php?mod=print&subaction=showfull&year=$1&month=$2&day=$3&news_page=$4&news_name=$5&seourl=$5 [QSA,L]
	RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})/(.*).html$ index.php?subaction=showfull&year=$1&month=$2&day=$3&news_name=$4&seourl=$4 [QSA,L]

	RewriteRule ^([^.]+)/page,([0-9]+),([0-9]+),([0-9]+)-(.*).html$ index.php?newsid=$4&news_page=$2&cstart=$3&seourl=$5&seocat=$1 [QSA,L]
	RewriteRule ^([^.]+)/page,([0-9]+),([0-9]+)-(.*).html$ index.php?newsid=$3&news_page=$2&seourl=$4&seocat=$1 [QSA,L]
	RewriteRule ^([^.]+)/print:page,([0-9]+),([0-9]+)-(.*).html$ index.php?mod=print&news_page=$2&newsid=$3&seourl=$4&seocat=$1 [QSA,L]
	RewriteRule ^([^.]+)/([0-9]+)-(.*).html$ index.php?newsid=$2&seourl=$3&seocat=$1 [QSA,L]

	RewriteRule ^page,([0-9]+),([0-9]+),([0-9]+)-(.*).html$ index.php?newsid=$3&news_page=$1&cstart=$2&seourl=$4 [QSA,L]
	RewriteRule ^page,([0-9]+),([0-9]+)-(.*).html$ index.php?newsid=$2&news_page=$1&seourl=$3 [QSA,L]
	RewriteRule ^print:page,([0-9]+),([0-9]+)-(.*).html$ index.php?mod=print&news_page=$1&newsid=$2&seourl=$3 [QSA,L]
	RewriteRule ^([0-9]+)-(.*).html$ index.php?newsid=$1&seourl=$2 [QSA,L]

	RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})(/?)+$ index.php?year=$1&month=$2&day=$3 [QSA,L]
	RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})/page/([0-9]+)(/?)+$ index.php?year=$1&month=$2&day=$3&cstart=$4 [QSA,L]

	RewriteRule ^([0-9]{4})/([0-9]{2})(/?)+$ index.php?year=$1&month=$2 [QSA,L]
	RewriteRule ^([0-9]{4})/([0-9]{2})/page/([0-9]+)(/?)+$ index.php?year=$1&month=$2&cstart=$3 [QSA,L]

	RewriteRule ^([0-9]{4})(/?)+$ index.php?year=$1 [QSA,L]
	RewriteRule ^([0-9]{4})/page/([0-9]+)(/?)+$ index.php?year=$1&cstart=$2 [QSA,L]

	RewriteRule ^tags/([^/]*)(/?)+$ index.php?do=tags&tag=$1 [B,QSA,L]
	RewriteRule ^tags/([^/]*)/page/([0-9]+)(/?)+$ index.php?do=tags&tag=$1&cstart=$2 [B,QSA,L]

	RewriteRule ^xfsearch/(.*)/page/([0-9]+)(/?)+$ index.php?do=xfsearch&xf=$1&cstart=$2 [B,QSA,L]
	RewriteRule ^xfsearch/(.*)/?$ index.php?do=xfsearch&xf=$1 [B,QSA,L]

	RewriteRule ^search/advanced(/?)+$ index.php?do=search&mode=advanced [QSA,L]
	RewriteRule ^search(/?)+$ index.php?do=search [QSA,L]
	RewriteRule ^contact(/?)+$ index.php?do=feedback [QSA,L]
	RewriteRule ^register(/?)+$ index.php?do=register [QSA,L]
	RewriteRule ^lostpassword(/?)+$ index.php?do=lostpassword [QSA,L]
	RewriteRule ^lastcomments(/?)+$ index.php?do=lastcomments [QSA,L]
	RewriteRule ^lastcomments/user/([0-9]+)(/?)+$ index.php?do=lastcomments&userid=$1 [QSA,L]

	RewriteRule ^user/([^/]*)/rss.xml$ index.php?mod=rss&subaction=allnews&user=$1 [B,QSA,L]
	RewriteRule ^user/([^/]*)/rssturbo.xml$ index.php?mod=rss&subaction=allnews&rssmode=turbo&user=$1 [B,QSA,L]
	RewriteRule ^user/([^/]*)/rssdzen.xml$ index.php?mod=rss&subaction=allnews&rssmode=dzen&user=$1 [B,QSA,L]
	RewriteRule ^user/([^/]*)(/?)+$ index.php?subaction=userinfo&user=$1 [B,QSA,L]
	RewriteRule ^user/([^/]*)/page/([0-9]+)(/?)+$ index.php?subaction=userinfo&user=$1&cstart=$2 [B,QSA,L]
	RewriteRule ^user/([^/]*)/news(/?)+$ index.php?subaction=allnews&user=$1 [B,QSA,L]
	RewriteRule ^user/([^/]*)/news/page/([0-9]+)(/?)+$ index.php?subaction=allnews&user=$1&cstart=$2 [B,QSA,L]

	RewriteRule ^lastnews(/?)+$ index.php?do=lastnews [QSA,L]
	RewriteRule ^lastnews/page/([0-9]+)(/?)+$ index.php?do=lastnews&cstart=$1 [QSA,L]

	RewriteRule ^catalog/([^/]*)/rss.xml$ index.php?mod=rss&catalog=$1 [QSA,L]
	RewriteRule ^catalog/([^/]*)/rssturbo.xml$ index.php?mod=rss&rssmode=turbo&catalog=$1 [QSA,L]
	RewriteRule ^catalog/([^/]*)/rssdzen.xml$ index.php?mod=rss&rssmode=dzen&catalog=$1 [QSA,L]
	RewriteRule ^catalog/([^/]*)(/?)+$ index.php?catalog=$1 [QSA,L]
	RewriteRule ^catalog/([^/]*)/page/([0-9]+)(/?)+$ index.php?catalog=$1&cstart=$2 [QSA,L]

	RewriteRule ^newposts(/?)+$ index.php?subaction=newposts [QSA,L]
	RewriteRule ^newposts/page/([0-9]+)(/?)+$ index.php?subaction=newposts&cstart=$1 [QSA,L]

	RewriteRule ^favorites(/?)+$ index.php?do=favorites [QSA,L]
	RewriteRule ^favorites/page/([0-9]+)(/?)+$ index.php?do=favorites&cstart=$1 [QSA,L]

	RewriteRule ^rules.html$ index.php?do=rules [QSA,L]
	RewriteRule ^statistics.html$ index.php?do=stats [QSA,L]
	RewriteRule ^addnews.html$ index.php?do=addnews [QSA,L]
	RewriteRule ^rss.xml$ index.php?mod=rss [QSA,L]
	RewriteRule ^rssturbo.xml$ index.php?mod=rss&rssmode=turbo [QSA,L]
	RewriteRule ^rssdzen.xml$ index.php?mod=rss&rssmode=dzen [QSA,L]
	RewriteRule ^sitemap.xml$ uploads/sitemap.xml [L]
	RewriteRule ^google_news.xml$ uploads/google_news.xml [L]
	RewriteRule ^google_news_([a-z]{2})\.xml$ uploads/google_news_$1.xml [L,NC]
	RewriteRule ^static_pages.xml$ uploads/static_pages.xml [L]
	RewriteRule ^static_pages_([a-z]{2})\.xml$ uploads/static_pages_$1.xml [L,NC]
	RewriteRule ^category_pages.xml$ uploads/category_pages.xml [L]
	RewriteRule ^category_pages_([a-z]{2})\.xml$ uploads/category_pages_$1.xml [L,NC]
	RewriteRule ^tags_pages.xml$ uploads/tags_pages.xml [L]
	RewriteRule ^tags_pages_([a-z]{2})\.xml$ uploads/tags_pages_$1.xml [L,NC]
	RewriteRule ^news_pages(\d*?).xml$ uploads/news_pages$1.xml [L]
	RewriteRule ^news_pages_([a-z]{2})(\d*?)\.xml$ uploads/news_pages_$1$2.xml [L,NC]

	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([^.]+)/page/([0-9]+)(/?)+$ index.php?do=cat&category=$1&cstart=$2 [QSA,L]
	RewriteRule ^([^.]+)/?$ index.php?do=cat&category=$1 [QSA,L]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^([^.]+)/rss.xml$ index.php?mod=rss&do=cat&category=$1 [QSA,L]
	RewriteRule ^([^.]+)/rssturbo.xml$ index.php?mod=rss&do=cat&rssmode=turbo&category=$1 [QSA,L]
	RewriteRule ^([^.]+)/rssdzen.xml$ index.php?mod=rss&do=cat&rssmode=dzen&category=$1 [QSA,L]
	RewriteRule ^page,([0-9]+),([^/]+).html$ index.php?do=static&page=$2&news_page=$1&seourl=$2 [QSA,L]
	RewriteRule ^print:([^/]+).html$ index.php?mod=print&do=static&page=$1&seourl=$1 [QSA,L]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^([^/]+).html$ index.php?do=static&page=$1&seourl=$1 [QSA,L]
</IfModule>
