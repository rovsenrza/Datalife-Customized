'ignore_error_1'			=>	"This user is already in the list of ignored users.",
'ignore_error_2'			=>	"You can't ignore users from admin groups.",
'ignore_ok'			=>	"The sender has been added to the list of ignored users. You will no longer receive messages from this user. You can unblock a user in your profile on the site.",
'ignore_del_ok'			=>	"The user has been removed from the list of ignored users.",
'cat_news_count'			=>	"Nəşrlər:",
